// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum Status {
    PENDING
    PROCESSING
    COMPLETED
    FAILED
}

model Video {
    id          String   @id @default(uuid())
    name        String
    userId      String // will use clerk id here
    size        BigInt // in bytes
    duration    Int // in seconds
    width       Int
    height      Int
    originalUrl String // s3 org-url
    createdAt   DateTime @default(now())
    jobs        Job[]

    @@index([userId])
}

model Job {
    id           String    @id @default(uuid())
    videoId      String
    video        Video     @relation(fields: [videoId], references: [id])
    status       Status    @default(PENDING)
    progress     Int       @default(0)
    outputConfig Json // will contain resolution, format, includeaudio, etc (TranscodeJobBodyconfig) 
    outputUrl    String? // output s3 url
    errorMessage String?
    startedAt    DateTime?
    finishedAt   DateTime?
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt

    @@index([videoId])
    @@index([status])
}
